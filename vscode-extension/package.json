{
  "name": "agent-actions",
  "displayName": "Agent Actions",
  "description": "YAML language support for Agent Actions workflows — autocomplete, validation, and go-to-definition.",
  "version": "0.1.8",
  "publisher": "runagac",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Muizzkolapo/agent-actions"
  },
  "homepage": "https://docs.runagac.com",
  "bugs": {
    "url": "https://github.com/Muizzkolapo/agent-actions/issues"
  },
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Other"
  ],
  "keywords": [
    "agent-actions",
    "llm",
    "yaml",
    "workflow",
    "ai",
    "agents",
    "agac"
  ],
  "activationEvents": [
    "workspaceContains:**/agent_actions.yml",
    "workspaceContains:**/agent_config/*.yml",
    "onView:agentActionsWorkflow",
    "onView:agentActionsInfo",
    "onView:agentActionsHelp"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentActions",
          "title": "Agent Actions",
          "icon": "media/icons/agent-actions-sidebar.svg"
        }
      ]
    },
    "views": {
      "agentActions": [
        {
          "id": "agentActionsWorkflow",
          "name": "Workflows",
          "icon": "$(list-tree)",
          "contextualTitle": "Workflow Navigator"
        },
        {
          "id": "agentActionsInfo",
          "name": "Extension Info",
          "visibility": "collapsed",
          "contextualTitle": "Agent Actions Info"
        },
        {
          "id": "agentActionsHelp",
          "name": "Help",
          "visibility": "collapsed",
          "contextualTitle": "Agent Actions Help"
        }
      ]
    },
    "commands": [
      {
        "command": "agentActions.restartServer",
        "title": "Agent Actions: Restart LSP Server"
      },
      {
        "command": "agentActions.refreshWorkflows",
        "title": "Agent Actions: Refresh Workflows",
        "icon": "$(refresh)"
      },
      {
        "command": "agentActions.openConfig",
        "title": "Agent Actions: Open Action Config"
      },
      {
        "command": "agentActions.openDocs",
        "title": "Agent Actions: Open Documentation"
      },
      {
        "command": "agentActions.previewData",
        "title": "Agent Actions: Preview Action Data",
        "icon": "$(database)"
      },
      {
        "command": "agentActions.showDAG",
        "title": "Agent Actions: Show Workflow DAG",
        "icon": "$(graph)"
      },
      {
        "command": "agentActions.goToAction",
        "title": "Agent Actions: Go to Action"
      },
      {
        "command": "agentActions.showWorkflowTree",
        "title": "Agent Actions: Show Workflow Tree"
      },
      {
        "command": "agentActions.openSettings",
        "title": "Agent Actions: Open Settings"
      },
      {
        "command": "agentActions.nextPage",
        "title": "Agent Actions: Next Page"
      },
      {
        "command": "agentActions.previousPage",
        "title": "Agent Actions: Previous Page"
      }
    ],
    "configuration": {
      "title": "Agent Actions",
      "properties": {
        "agentActions.interpreter": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "scope": "resource",
          "description": "Path to the Python interpreter used to run the LSP server. If empty, the interpreter from the Python extension is used."
        },
        "agentActions.serverPath": {
          "type": "string",
          "default": "agac-lsp",
          "description": "Path to a standalone agac-lsp binary. Overrides interpreter-based discovery. Defaults to 'agac-lsp' on PATH."
        },
        "agentActions.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace LSP communication for debugging."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "build": "node esbuild.js --production",
    "typecheck": "tsc --noEmit",
    "package": "npm run typecheck && npm run build && vsce package",
    "publish": "npm run typecheck && npm run build && vsce publish"
  },
  "dependencies": {
    "@vscode/python-extension": "^1.0.5",
    "vscode-languageclient": "^9.0.1",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.0.0"
  }
}
