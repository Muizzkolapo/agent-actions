{
  "features": {
    "customer_tenure_days": {
      "type": "numeric",
      "description": "Days since customer first purchase",
      "transformations": [
        "log_transform",
        "bin_into_segments"
      ],
      "business_meaning": "Customer loyalty indicator",
      "typical_range": [0, 3650],
      "importance": "high"
    },
    "purchase_frequency": {
      "type": "numeric",
      "description": "Average purchases per month",
      "transformations": [
        "clip_outliers",
        "standardize"
      ],
      "business_meaning": "Engagement level",
      "typical_range": [0, 50],
      "importance": "high"
    },
    "average_order_value": {
      "type": "numeric",
      "description": "Mean order value in USD",
      "transformations": [
        "log_transform",
        "standardize"
      ],
      "business_meaning": "Customer spending power",
      "typical_range": [10, 5000],
      "importance": "high"
    },
    "days_since_last_purchase": {
      "type": "numeric",
      "description": "Recency of last purchase",
      "transformations": [
        "inverse_transform",
        "clip_outliers"
      ],
      "business_meaning": "Churn risk indicator",
      "typical_range": [0, 365],
      "importance": "critical"
    },
    "product_category_diversity": {
      "type": "numeric",
      "description": "Number of distinct product categories purchased",
      "transformations": [
        "normalize"
      ],
      "business_meaning": "Customer breadth of interest",
      "typical_range": [1, 20],
      "importance": "medium"
    },
    "support_ticket_count": {
      "type": "numeric",
      "description": "Total support tickets filed",
      "transformations": [
        "log_transform",
        "flag_high_values"
      ],
      "business_meaning": "Satisfaction proxy",
      "typical_range": [0, 100],
      "importance": "medium"
    },
    "email_engagement_rate": {
      "type": "numeric",
      "description": "Email open rate percentage",
      "transformations": [
        "clip_to_0_1"
      ],
      "business_meaning": "Marketing receptiveness",
      "typical_range": [0, 1],
      "importance": "medium"
    },
    "preferred_device": {
      "type": "categorical",
      "description": "Primary device used (mobile, desktop, tablet)",
      "encoding": "one_hot",
      "categories": ["mobile", "desktop", "tablet"],
      "business_meaning": "User behavior pattern",
      "importance": "low"
    },
    "customer_segment": {
      "type": "categorical",
      "description": "Marketing segment (VIP, regular, occasional)",
      "encoding": "ordinal",
      "categories": ["occasional", "regular", "VIP"],
      "ordering": [0, 1, 2],
      "business_meaning": "Pre-assigned value tier",
      "importance": "high"
    },
    "acquisition_channel": {
      "type": "categorical",
      "description": "How customer was acquired",
      "encoding": "one_hot",
      "categories": ["organic", "paid_search", "social", "referral", "email"],
      "business_meaning": "Marketing effectiveness",
      "importance": "low"
    }
  },
  "derived_features": {
    "rfm_score": {
      "formula": "combine(recency_score, frequency_score, monetary_score)",
      "dependencies": ["days_since_last_purchase", "purchase_frequency", "average_order_value"],
      "description": "Classic RFM segmentation score",
      "importance": "critical"
    },
    "engagement_momentum": {
      "formula": "purchase_frequency_last_30d / purchase_frequency_last_90d",
      "dependencies": ["purchase_frequency"],
      "description": "Trend in customer engagement",
      "importance": "high"
    },
    "value_velocity": {
      "formula": "average_order_value_last_30d - average_order_value_last_90d",
      "dependencies": ["average_order_value"],
      "description": "Change in spending behavior",
      "importance": "medium"
    }
  },
  "feature_engineering_templates": {
    "temporal_aggregations": {
      "description": "Aggregate metrics over time windows",
      "windows": ["7d", "30d", "90d", "365d"],
      "aggregations": ["sum", "mean", "std", "min", "max"]
    },
    "interaction_features": {
      "description": "Create feature interactions",
      "pairs": [
        ["customer_tenure_days", "purchase_frequency"],
        ["average_order_value", "purchase_frequency"],
        ["days_since_last_purchase", "email_engagement_rate"]
      ]
    },
    "ratio_features": {
      "description": "Create ratio-based features",
      "ratios": [
        {"numerator": "support_ticket_count", "denominator": "purchase_frequency"},
        {"numerator": "average_order_value", "denominator": "customer_tenure_days"}
      ]
    }
  },
  "data_quality_rules": {
    "completeness": {
      "critical_features": ["days_since_last_purchase", "purchase_frequency", "customer_tenure_days"],
      "min_non_null_percentage": 0.95
    },
    "consistency": {
      "rules": [
        "customer_tenure_days >= days_since_last_purchase",
        "purchase_frequency >= 0",
        "average_order_value > 0 if purchase_frequency > 0"
      ]
    },
    "outlier_detection": {
      "method": "iqr",
      "threshold": 3.0,
      "features": ["average_order_value", "purchase_frequency", "support_ticket_count"]
    }
  }
}
